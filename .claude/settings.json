{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ramonehamilton/Documents/Personal Projects/MTGA-Companion/.claude/hooks/architect-pre-push.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "if": "Bash(gh pr create*)",
            "prompt": "You are the lead-engineer code reviewer. An agent is about to open a pull request. Review all changes on the current branch by running: git diff main...HEAD and git log main...HEAD --oneline. Check against CLAUDE.md rules — flag over-engineering, scope creep, unnecessary complexity, missing tests, or any violations of project conventions.\n\nIf the PR is ready, output ONLY this exact JSON: {\"continue\": true}\nIf the PR should be blocked, output ONLY this exact JSON: {\"continue\": false, \"stopReason\": \"Lead Engineer BLOCKED: <your specific reason>\"}\n\nOutput nothing else.",
            "timeout": 120,
            "statusMessage": "Lead Engineer reviewing changes before PR..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(go *)",
      "Bash(gofumpt *)",
      "Bash(golangci-lint *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(curl *)",
      "Bash(sqlite3 *)",
      "Bash(python3 *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(export *)",
      "Bash(env *)",
      "Bash(aws secretsmanager *)",
      "Bash(aws rds *)",
      "Bash(aws configure *)",
      "Bash(~/go/bin/gofumpt *)",
      "Bash(/Users/ramonehamilton/go/bin/gofumpt *)",
      "Bash(GOWORK=off go *)",
      "Bash(GOEXPERIMENT=* go *)",
      "Bash(wait)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:app.codecov.io)",
      "WebFetch(domain:api.scryfall.com)",
      "WebFetch(domain:scryfall.com)",
      "WebFetch(domain:mtgjson.com)",
      "WebFetch(domain:whatsinstandard.com)",
      "WebFetch(domain:mtgazone.com)",
      "WebFetch(domain:edhrec.com)",
      "WebFetch(domain:archidekt.com)",
      "WebFetch(domain:docs.coderabbit.ai)",
      "WebFetch(domain:tip.golang.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:www.channelfireball.com)",
      "WebFetch(domain:strategy.channelfireball.com)",
      "WebFetch(domain:lrcast.com)",
      "WebFetch(domain:www.tcgplayer.com)",
      "WebFetch(domain:www.mtgsalvation.com)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:aws.amazon.com)",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_index",
      "Read(~/.claude/plans/**)",
      "Read(~/.claude/projects/**)"
    ],
    "deny": [],
    "ask": []
  }
}
