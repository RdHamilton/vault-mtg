# BFF base URL (including /api/v1 path prefix).
# Set this in the Vercel dashboard per environment (Production + Preview).
# For production (S3+CloudFront), set VITE_BFF_URL=https://api.vaultmtg.app/api/v1 at build time.
# Leave unset for local development — the client defaults to http://localhost:8080/api/v1.
# See docs/adr/006-vercel-bff-connectivity.md and docs/adr/ADR-008-frontend-serving-model.md.
VITE_BFF_URL=https://api.vaultmtg.app/api/v1

# Clerk publishable key — required for auth UI (ADR-009).
# Get your key from https://dashboard.clerk.com → API Keys.
# Use pk_test_... for development, pk_live_... for production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
