# =============================================================================
# VaultMTG Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is in .gitignore.
#
# Vercel sets env vars per environment in the project dashboard.
# The three environments and their expected values are documented below.
# See docs/adr/staging-environment-design.md for the full staging design.
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_BFF_URL — BFF REST API base URL (includes /api/v1 path prefix)
# -----------------------------------------------------------------------------
# Set this in the Vercel dashboard per environment; do NOT hardcode the URL
# in source. See docs/adr/006-vercel-bff-connectivity.md and ADR-008.
#
# | Vercel environment | Value                                          |
# |--------------------|------------------------------------------------|
# | Production         | https://api.vaultmtg.app/api/v1                |
# | Preview (PR)       | https://staging-api.vaultmtg.app/api/v1        |
# | Development (local)| http://localhost:8080/api/v1 (default fallback) |
#
# "Preview" = every Vercel PR preview build. Preview deploys point at the
# staging BFF (staging-api.vaultmtg.app) so they never touch production data.
# "Development" = `vercel dev` or `vite dev` locally. When this var is unset
# the client falls back to http://localhost:8080/api/v1 automatically.
#
# Production build (S3+CloudFront, per ADR-008) injects this at build time via
# the GitHub Actions deploy workflow — not via Vercel's production environment.
VITE_BFF_URL=http://localhost:8080/api/v1

# -----------------------------------------------------------------------------
# VITE_DAEMON_URL — Local daemon REST API base URL (includes /api/v1 path prefix)
# -----------------------------------------------------------------------------
# The MTGA log-parsing daemon always runs locally on the user's machine.
# This URL is the same in all environments because the daemon is never remote.
#
# | Environment        | Value                          |
# |--------------------|--------------------------------|
# | Production         | http://localhost:9001/api/v1   |
# | Preview (PR)       | http://localhost:9001/api/v1   |
# | Development (local)| http://localhost:9001/api/v1   |
VITE_DAEMON_URL=http://localhost:9001/api/v1

# -----------------------------------------------------------------------------
# VITE_CLERK_PUBLISHABLE_KEY — Clerk auth publishable key (ADR-009)
# -----------------------------------------------------------------------------
# Get your key from https://dashboard.clerk.com → API Keys.
# Only pk_* (publishable) keys belong in the frontend bundle.
# NEVER put a sk_* (secret) key here — it would be exposed to browsers.
#
# | Vercel environment | Clerk instance       | Key prefix  |
# |--------------------|----------------------|-------------|
# | Production         | Production instance  | pk_live_*   |
# | Preview (PR)       | Development instance | pk_test_*   |
# | Development (local)| Development instance | pk_test_*   |
#
# Preview and local dev share the same Clerk Development instance.
# Test users created during PR review do not pollute the production Clerk
# instance and do not count toward production Monthly Active User billing.
#
# Social OAuth providers (Google, Facebook, Apple) are enabled in the Clerk
# Dashboard under Social connections — no additional frontend code required.
# Dashboard: https://dashboard.clerk.com → Social connections
# Docs: https://clerk.com/docs/authentication/social-connections/overview
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# -----------------------------------------------------------------------------
# VITE_POSTHOG_KEY — PostHog analytics project API key
# -----------------------------------------------------------------------------
# Leave unset (or empty) to disable all analytics calls.
# Safe to leave empty for local dev and tests — the PostHog module is a no-op
# when this var is absent.
# Get your key from https://app.posthog.com → Project Settings → API Keys.
#
# | Vercel environment | Recommended value                  |
# |--------------------|------------------------------------|
# | Production         | phc_<live-project-key>             |
# | Preview (PR)       | phc_<staging-project-key> (or same)|
# | Development (local)| leave empty                        |
VITE_POSTHOG_KEY=

# PostHog ingestion host. Default is the US cloud.
# Override to https://eu.posthog.com for the EU cloud or a self-hosted instance.
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# VITE_SENTRY_DSN — Sentry error monitoring DSN
# -----------------------------------------------------------------------------
# Leave empty (or unset) in local dev and test — Sentry.init() is skipped.
# Set to the project DSN from https://sentry.io → Project Settings → Client Keys.
# Sentry uses the same project for all environments; the MTGA_ENV value
# (staging vs. production) is sent as the Sentry "environment" tag.
#
# | Vercel environment | Recommended value          |
# |--------------------|----------------------------|
# | Production         | https://...@sentry.io/...  |
# | Preview (PR)       | same DSN, env tag=staging  |
# | Development (local)| leave empty                |
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# VITE_GA4_MEASUREMENT_ID — Google Analytics 4 Measurement ID
# -----------------------------------------------------------------------------
# Leave empty (or unset) in local dev and test — the gtag.js snippet is
# guarded by this value and will not load unless it is set.
# Format: G-XXXXXXXXXX
# Set as a GitHub Actions repository variable for production builds.
#
# | Environment        | Recommended value          |
# |--------------------|----------------------------|
# | Production         | G-XXXXXXXXXX               |
# | Preview (PR)       | leave empty                |
# | Development (local)| leave empty                |
VITE_GA4_MEASUREMENT_ID=
