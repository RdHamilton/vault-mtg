{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=full",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:full": "playwright test --project=full",
    "test:e2e:cross-browser": "playwright test --project=smoke --project=firefox --project=webkit",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:pipeline": "USE_LOG_FIXTURES=true playwright test --project=pipeline",
    "screenshots": "playwright test --project=screenshots",
    "test:staging": "playwright test --config=playwright.staging.config.ts",
    "test:e2e:staging-spa": "playwright test --config=playwright.staging-spa.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@clerk/react": "^6.6.0",
    "@clerk/ui": "^1.10.0",
    "@sentry/react": "^10.52.0",
    "posthog-js": "^1.372.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.4.1"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.13.4",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chromatic": "^16.9.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.0.1",
    "msw": "^2.12.7",
    "storybook": "^10.3.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^3.2.4"
  }
}
