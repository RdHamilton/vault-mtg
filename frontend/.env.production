# Production BFF URL — baked into the SPA at build time for S3+CloudFront deploys.
# See docs/adr/ADR-008-frontend-serving-model.md.
VITE_BFF_URL=https://api.vaultmtg.app/api/v1

# Local daemon URL — the MTGA log-parsing daemon always runs on localhost.
# Port 9001 matches services/daemon/internal/localapi server bind.
VITE_DAEMON_URL=http://localhost:9001/api/v1
