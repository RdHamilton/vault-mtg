# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output directory
bin/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# SQLite database files
*.sqlite
*.sqlite3
*.db

# Dependency directories (remove the comment below to include it)
# vendor/


# env file
.env

# Editor/IDE
.idea/
.vscode/

# AI specific files
.reference-notes.md
.cursorrules
Icon.png
!services/daemon/internal/tray/assets/icon.png

# Claude Code agent worktrees (temporary workspaces, never committed)
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Root-level node_modules (tooling deps not tied to frontend/)
node_modules/

# MTG Arena log file (dropped at repo root for local spike analysis — never commit)
Player.log

# macOS metadata
.DS_Store

# GoReleaser build output
services/daemon/dist/

# Frontend (Vite/React)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/
frontend/coverage/

# Playwright E2E testing
frontend/test-results/
frontend/playwright-report/
frontend/playwright-report-*/
frontend/.auth/
apiserver

# Windows resource object generated by goversioninfo at release time (#307).
# Embeds the app icon into vaultmtg-daemon.exe; never committed — regenerated
# from versioninfo.json + install/icons/vaultmtg.ico during the GoReleaser build.
services/daemon/cmd/daemon/resource.syso

# Local Go build outputs (binaries built next to package main.go)
services/daemon/daemon
services/collection-agent-helper/mtga-collection-helper
services/collection-agent-helper/collection-helper
services/collection-poc/mtga-collection-poc
